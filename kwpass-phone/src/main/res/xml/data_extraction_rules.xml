<?xml version="1.0" encoding="utf-8"?><!--
   Sample data extraction rules file; uncomment and customize as necessary.
   See https://developer.android.com/about/versions/12/backup-restore#xml-changes
   for details.
-->

<!-- preferencesDataStore(name = "userInfo")로 저장되어 files/datastore/userInfo.preferences_pb에 저장됨-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="file" path="datastore/userInfo.preferences_pb"/>
    </cloud-backup>

    <device-transfer>
        <exclude domain="file" path="datastore/userInfo.preferences_pb"/>
    </device-transfer>
</data-extraction-rules>